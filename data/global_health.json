[
  {"term":"Pandemic","definition":"Disease spreading worldwide.","example":"Like a cold spreading across the whole school."},
  {"term":"Epidemic","definition":"Disease spreading quickly in one region.","example":"Like many students catching the flu."},
  {"term":"Vaccination","definition":"Medicine protecting people from diseases.","example":"Like wearing armor against germs."},
  {"term":"Public Health","definition":"Protecting health of communities.","example":"Like school hygiene rules."},
  {"term":"Healthcare System","definition":"Hospitals and doctors in a country.","example":"Like the nurse's office in school."},
  {"term":"Disease Prevention","definition":"Stopping illness before it spreads.","example":"Like washing hands."},
  {"term":"Medical Research","definition":"Studying diseases to find cures.","example":"Like scientists solving puzzles."},
  {"term":"Health Policy","definition":"Government rules about healthcare.","example":"Like school rules for health safety."},
  {"term":"Global Immunization","definition":"Vaccination programs worldwide.","example":"Like giving every student protection."},
  {"term":"Disease Surveillance","definition":"Tracking diseases.","example":"Like monitoring attendance for sick students."},
  {"term":"Mental Health","definition":"Emotional and psychological wellbeing.","example":"Like helping students feel happy."},
  {"term":"Nutrition Programs","definition":"Efforts to provide healthy food.","example":"Like school lunch programs."},
  {"term":"Health Equity","definition":"Equal healthcare for everyone.","example":"Like every student getting help from the nurse."},
  {"term":"Medical Aid","definition":"Doctors helping during disasters.","example":"Like emergency helpers."},
  {"term":"Hospital Infrastructure","definition":"Buildings and equipment for healthcare.","example":"Like classrooms for doctors."},
  {"term":"Health Education","definition":"Teaching people about healthy habits.","example":"Like learning about brushing teeth."},
  {"term":"Disease Control","definition":"Stopping illnesses from spreading.","example":"Like isolating sick students."},
  {"term":"Health Emergency","definition":"Serious disease outbreak.","example":"Like a sudden illness affecting many people."},
  {"term":"Health Campaign","definition":"Programs promoting health awareness.","example":"Like posters reminding students to wash hands."},
  {"term":"Global Health Cooperation","definition":"Countries working together on health issues.","example":"Like schools helping each other during illness outbreaks."},
  {"term":"Infectious Disease","definition":"Illness that spreads from person to person.","example":"Like sharing a cold with friends."},
  {"term":"Health Worker","definition":"Doctors, nurses, and medical staff.","example":"Like the school nurse helping students."},
  {"term":"Preventive Care","definition":"Actions to stop people from getting sick.","example":"Like getting a flu shot."},
  {"term":"Health Infrastructure","definition":"Clinics and hospitals.","example":"Like the nurse's office and doctor visits."},
  {"term":"Maternal Health","definition":"Healthcare for pregnant women and mothers.","example":"Like special care for moms."}
