[
  {"term":"Migration","definition":"People moving from one place to another.","example":"Like moving to a new school."},
  {"term":"Immigration","definition":"Entering another country to live there.","example":"Like joining a new class."},
  {"term":"Emigration","definition":"Leaving your home country.","example":"Like transferring schools."},
  {"term":"Refugee","definition":"Someone fleeing danger or war.","example":"Like a friend escaping bullying."},
  {"term":"Asylum","definition":"Protection given to refugees.","example":"Like letting a friend stay at your house."},
  {"term":"Border Crossing","definition":"Moving across national borders.","example":"Like entering another school."},
  {"term":"Migration Policy","definition":"Rules about immigration.","example":"Like rules for new students joining school."},
  {"term":"Economic Migration","definition":"Moving for better job opportunities.","example":"Like changing schools for better education."},
  {"term":"Forced Migration","definition":"People forced to leave homes.","example":"Like evacuating during a storm."},
  {"term":"Diaspora","definition":"Community living outside its homeland.","example":"Like classmates from the same town."},
  {"term":"Border Security","definition":"Protecting national borders.","example":"Like guards at school gates."},
  {"term":"Integration","definition":"Helping newcomers fit into society.","example":"Like helping a new student make friends."},
  {"term":"Resettlement","definition":"Helping refugees settle in new places.","example":"Like welcoming a transfer student."},
  {"term":"Migrant Workers","definition":"People working in another country.","example":"Like students helping another class."},
  {"term":"Migration Flow","definition":"Movement of many people.","example":"Like students moving between classrooms."},
  {"term":"Refugee Camp","definition":"Temporary place for displaced people.","example":"Like emergency shelters."},
  {"term":"Legal Migration","definition":"Moving according to laws.","example":"Like enrolling officially in school."},
  {"term":"Irregular Migration","definition":"Moving without official permission.","example":"Like sneaking into a class."},
  {"term":"Citizenship","definition":"Legal membership in a country.","example":"Like belonging to a school."},
  {"term":"Naturalization","definition":"Process of becoming a citizen.","example":"Like officially joining a new team."},
  {"term":"Humanitarian Protection","definition":"Safety for people in danger.","example":"Like protecting a friend from bullying."},
  {"term":"Migration Rights","definition":"Laws protecting migrants.","example":"Like rules protecting students' safety."},
  {"term":"Host Country","definition":"Country receiving immigrants.","example":"Like a school accepting new students."},
  {"term":"Displacement","definition":"Forced movement from home.","example":"Like having to leave your classroom."},
  {"term":"Repatriation","definition":"Returning people to their home country.","example":"Like transferring a student back to their original school."}
]